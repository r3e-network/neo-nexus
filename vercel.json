{
  "version": 2,
  "builds": [
    { "src": "website/package.json", "use": "@vercel/next" },
    { "src": "dashboard/package.json", "use": "@vercel/next" }
  ],
  "rewrites": [
    {
      "source": "/app/(.*)",
      "destination": "/dashboard/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/website/$1"
    }
  ]
}
