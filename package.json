{
  "name": "neo-nexus",
  "version": "2.1.0",
  "description": "Professional Neo Node Manager - Deploy and manage Neo N3 nodes locally",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:web",
    "build:web": "cd web && npm run build",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "cd web && npm run dev",
    "start": "NODE_ENV=production node --import tsx dist/index.js",
    "start:prod": "NODE_ENV=production node --import tsx dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "neo",
    "neo-n3",
    "blockchain",
    "node-manager",
    "neo-cli",
    "neo-go"
  ],
  "author": "NeoNexus Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "extract-zip": "^2.0.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "ps-list": "^8.1.1",
    "systeminformation": "^5.25.11",
    "tar": "^7.4.3",
    "tsx": "^4.19.0",
    "ws": "^8.18.1",
    "zod": "^3.25.40"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.36",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "eslint": "^9.26.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "typescript-transform-paths": "^3.5.6",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
