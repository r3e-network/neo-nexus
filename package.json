{
  "name": "neo-nexus",
  "version": "2.4.0",
  "description": "Professional Neo Node Manager - Deploy and manage Neo N3 nodes locally",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.build.json",
    "build:frontend": "npm --prefix web run build",
    "build:web": "npm run build:frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "start": "NODE_ENV=production node --import tsx dist/index.js",
    "lint": "npm run lint:backend && npm run lint:tests && npm run lint:frontend",
    "lint:backend": "eslint src/",
    "lint:tests": "eslint tests/",
    "lint:frontend": "npm --prefix web run lint",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest run",
    "test:frontend": "npm --prefix web run test",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "vitest run --coverage",
    "test:coverage:frontend": "npm --prefix web run test:coverage",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc --noEmit",
    "typecheck:frontend": "npm --prefix web run typecheck",
    "verify": "npm run verify:backend && npm run verify:frontend",
    "verify:backend": "npm run lint:backend && npm run lint:tests && npm run typecheck:backend && npm run test:backend",
    "verify:frontend": "npm run lint:frontend && npm run typecheck:frontend && npm run test:frontend && npm run build:frontend"
  },
  "keywords": [
    "neo",
    "neo-n3",
    "blockchain",
    "node-manager",
    "neo-cli",
    "neo-go"
  ],
  "author": "NeoNexus Team",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.46.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "extract-zip": "^2.0.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "ps-list": "^8.1.1",
    "systeminformation": "^5.25.11",
    "tar": "^7.4.3",
    "tsx": "^4.19.0",
    "ws": "^8.18.1",
    "zod": "^3.25.40"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.36",
    "@types/supertest": "^7.2.0",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.0.0",
    "eslint": "^9.26.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "typescript-transform-paths": "^3.5.6",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
